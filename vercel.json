{
  "buildCommand": "vite build && esbuild server/api.ts --bundle --platform=node --packages=external --format=esm --outfile=api/index.js",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
